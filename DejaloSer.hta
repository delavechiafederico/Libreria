<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <title>Dejalo Ser - Gestión de Libros</title>

    <hta:application 
        id="oDS_Final" 
        applicationname="DejaloSerABM" 
        border="normal" 
        caption="yes" 
        showintaskbar="yes" 
        singleinstance="yes" 
        sysmenu="yes" 
        maximizebutton="yes" 
        minimizebutton="yes" 
        windowstate="maximize" 
        scroll="no" 
        selection="yes" 
    />

    <style>
        * { box-sizing: border-box; }
        body {
            background-color: #fdf5e6;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            margin: 0; padding: 15px; color: #4a4a4a; overflow: hidden; font-size: 15px;
        }
        .wrapper {
            width: 98%; margin: 0 auto; background-color: #ffffff; padding: 20px;
            border-radius: 12px; border: 2px solid #b2c2bf; box-shadow: 6px 6px 0px #b2c2bf;
        }
        .main-title {
            text-align: center; color: #2d5a27; font-family: "Courier New", Courier, monospace;
            text-transform: uppercase; letter-spacing: 2px; border-bottom: 2px dashed #d9adad;
            padding-bottom: 10px; margin-bottom: 15px; font-size: 30px;
        }
        input, td, th { text-transform: uppercase; }
        .search-area { text-align: center; margin-bottom: 15px; }
        #txtBusqueda {
            font-family: "Courier New", Courier, monospace; font-weight: bold;
            padding: 10px; width: 55%; border: 2px solid #d9adad; border-radius: 6px;
            font-size: 18px; outline: none;
        }
        .btn {
            padding: 10px 15px; border: none; border-radius: 6px; cursor: pointer;
            font-weight: bold; text-transform: uppercase; font-size: 13px;
        }
        .btn-search { background-color: #77a8a8; color: white; }
        .btn-clear { background-color: #4a4a4a; color: #ffffff; margin-left: 5px; }
        .btn-new { background-color: #d9adad; color: white; margin-left: 5px; }
        .btn-edit { background-color: #b2c2bf; color: white; }
        .btn-delete { background-color: #f2d1d1; color: #a35d5d; margin-left: 5px; }
        .grid-wrapper { height: calc(100vh - 220px); overflow-y: auto; border: 1px solid #eee; background: #fff; }
        table { width: 100%; border-collapse: collapse; }
        th {
            background-color: #77a8a8; color: white; padding: 12px;
            font-family: "Courier New", Courier, monospace; position: sticky;
            top: 0; text-align: left; z-index: 5; font-size: 14px;
        }
        .inverted-th { background-color: white !important; color: #77a8a8 !important; border: 1px solid #77a8a8; }
        td { padding: 10px; border-bottom: 1px solid #f0f0f0; font-size: 14px; }
        tr:nth-child(even) { background-color: #faf8f5; }
        #modalOverlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.5); z-index: 1000;
        }
        #miniForm {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            background: #fff; width: 450px; padding: 25px; border: 5px solid #77a8a8; border-radius: 15px;
        }
        .form-group { margin-bottom: 12px; }
        .form-group label {
            display: block; font-size: 11px; font-weight: bold; color: #888;
            text-transform: uppercase; margin-bottom: 2px;
        }
        .form-group input { width: 100%; padding: 8px; border: 1px solid #d9adad; border-radius: 5px; font-size: 15px; }
    </style>

    <script language="javascript">
        var dbPath = "D:\\Dejalo Ser ABM\\Proyecto.mdb";
        var connStr = "Provider=Microsoft.Jet.OLEDB.4.0;Data Source=" + dbPath + ";";
        var editando = false;
        var isbnOriginal = "";
        var guardando = false;
        var intentoCierre = false;

        function safeFocus(id) {
            try { var el = document.getElementById(id); if (el) el.focus(); } catch (e) {}
        }

        function getConn() {
            var conn = new ActiveXObject("ADODB.Connection");
            conn.Open(connStr);
            return conn;
        }

        function esc(str) {
            if (str === null || str === undefined) return "";
            return String(str).replace(/'/g, "''").toUpperCase().replace(/^\s+|\s+$/g, "");
        }

        function inicializar() {
            try {
                window.moveTo(0, 0);
                window.resizeTo(screen.availWidth, screen.availHeight);
            } catch (e) {}
            limpiarBusqueda();
            
            document.onkeydown = function (e) {
                var code = (e || window.event).keyCode;
                if (code === 27) { 
                    confirmarSalida();
                } else {
                    intentoCierre = false;
                }
            };
        }

        function confirmarSalida() {
            if (intentoCierre) {
                window.close();
            } else {
                intentoCierre = true;
                if (confirm("¿DESEA CERRAR EL PROGRAMA?\n\n(ENTER para SI / ESC para cerrar definitivo)")) {
                    window.close();
                }
            }
        }

        function saltar(e, idSiguiente) {
            if ((e || window.event).keyCode === 13) {
                if (idSiguiente === "GUARDAR") guardar(false);
                else safeFocus(idSiguiente);
                return false;
            }
        }

        function setCabecerasNormal() {
            document.body.style.backgroundColor = "#fdf5e6";
            var ths = document.getElementsByTagName("th");
            for (var i = 0; i < ths.length; i++) ths[i].className = "";
        }

        function setCabecerasInvertidas() {
            document.body.style.backgroundColor = "#FFFFFF";
            var ths = document.getElementsByTagName("th");
            for (var i = 0; i < ths.length; i++) ths[i].className = "inverted-th";
        }

        function limpiarBusqueda() {
            document.getElementById('txtBusqueda').value = '';
            document.getElementById("tablaResultados").tBodies[0].innerHTML = "";
            setCabecerasInvertidas();
            intentoCierre = false;
            safeFocus("txtBusqueda");
        }

        function verificarExistenciaISBN() {
            if (editando) return;
            var isbn = esc(document.getElementById("f_isbn").value);
            if (isbn === "") return;

            var conn = null;
            try {
                conn = getConn();
                var rs = new ActiveXObject("ADODB.Recordset");
                rs.Open("SELECT ISBN FROM Libros WHERE ISBN='" + isbn + "'", conn, 3, 1);
                if (!rs.EOF) {
                    alert("¡ATENCIÓN! El ISBN " + isbn + " ya existe en la base de datos.");
                    document.getElementById("f_isbn").value = "";
                    safeFocus("f_isbn");
                }
                rs.Close();
            } catch(e) {} finally { if (conn) conn.Close(); }
        }

        function consultar() {
            var criterio = esc(document.getElementById("txtBusqueda").value);
            var tbody = document.getElementById("tablaResultados").tBodies[0];
            tbody.innerHTML = "";
            
            if (criterio === "") {
                setCabecerasInvertidas();
                return;
            } else {
                setCabecerasNormal();
            }

            var conn = null, rs = null;
            try {
                document.body.style.cursor = "wait";
                conn = getConn();
                rs = new ActiveXObject("ADODB.Recordset");
                var sql = "SELECT * FROM Libros WHERE ISBN LIKE '%" + criterio + "%' OR titulo LIKE '%" + criterio + "%' OR autor LIKE '%" + criterio + "%' ORDER BY titulo ASC";
                rs.Open(sql, conn, 3, 1);

                while (!rs.EOF) {
                    var row = tbody.insertRow(-1);
                    var d = {
                        isbn: String(rs.Fields("ISBN").Value || ""),
                        cod: String(rs.Fields("codigo").Value || ""),
                        tit: String(rs.Fields("titulo").Value || ""),
                        aut: String(rs.Fields("autor").Value || ""),
                        edi: String(rs.Fields("editorial").Value || ""),
                        lug: String(rs.Fields("lugar").Value || "")
                    };
                    row.insertCell(0).innerText = d.isbn;
                    row.insertCell(1).innerText = d.cod;
                    row.insertCell(2).innerText = d.tit;
                    row.insertCell(3).innerText = d.aut;
                    row.insertCell(4).innerText = d.edi;
                    row.insertCell(5).innerText = d.lug;
                    var actions = row.insertCell(6);
                    actions.innerHTML = "<button class='btn btn-edit'>EDITAR</button><button class='btn btn-delete'>BORRAR</button>";
                    
                    (function(data, cell) {
                        cell.children[0].onclick = function() { cargarParaEditar(data.isbn, data.cod, data.tit, data.aut, data.edi, data.lug); };
                        cell.children[1].onclick = function() { eliminar(data.isbn); };
                    })(d, actions);
                    rs.MoveNext();
                }
            } catch (e) { alert("Error: " + e.message); } finally {
                if (rs && rs.State === 1) rs.Close();
                if (conn && conn.State === 1) conn.Close();
                document.body.style.cursor = "default";
            }
        }

        function guardar(sinMensajeFinal) {
            if (guardando) return;
            guardando = true;
            var f = {
                isbn: esc(document.getElementById("f_isbn").value),
                cod: esc(document.getElementById("f_codigo").value),
                tit: esc(document.getElementById("f_titulo").value),
                aut: esc(document.getElementById("f_autor").value),
                edi: esc(document.getElementById("f_editorial").value),
                lug: esc(document.getElementById("f_lugar").value)
            };

            if (!f.isbn || !f.tit) { 
                alert("ISBN y TÍTULO son campos obligatorios."); 
                guardando = false; 
                return; 
            }

            var conn = null;
            try {
                document.body.style.cursor = "wait";
                conn = getConn();
                var sql = editando 
                    ? "UPDATE Libros SET codigo='"+f.cod+"', titulo='"+f.tit+"', autor='"+f.aut+"', editorial='"+f.edi+"', lugar='"+f.lug+"' WHERE ISBN='"+esc(isbnOriginal)+"'"
                    : "INSERT INTO Libros VALUES ('"+f.isbn+"','"+f.cod+"','"+f.tit+"','"+f.aut+"','"+f.edi+"','"+f.lug+"')";
                
                conn.Execute(sql);
                cerrarModal();

                // PEQUEÑA PAUSA PARA QUE EL MOTOR DE ACCESS TERMINE DE ESCRIBIR
                setTimeout(function() { 
                    consultar(); 
                    if (!sinMensajeFinal) alert("Guardado exitoso.");
                    guardando = false;
                }, 200);
            } catch (e) { 
                alert("Error al guardar: " + e.message); 
                guardando = false; 
            } finally { 
                if (conn) conn.Close(); 
                document.body.style.cursor = "default"; 
            }
        }

        function eliminar(isbn) {
            if (!confirm("¿SEGURO QUE DESEA ELIMINAR EL LIBRO ISBN " + isbn + "?")) return;
            var conn = null;
            try {
                conn = getConn();
                conn.Execute("DELETE FROM Libros WHERE ISBN='" + esc(isbn) + "'");
                consultar();
            } catch (e) { alert("Error al eliminar: " + e.message); } finally { if (conn) conn.Close(); }
        }

        function abrirModal(esEdit) {
            editando = esEdit;
            document.getElementById("modalTitulo").innerText = esEdit ? "EDITAR LIBRO" : "NUEVO LIBRO";
            document.getElementById("f_isbn").readOnly = esEdit;
            if (!esEdit) { isbnOriginal = ""; limpiarCampos(); }
            document.getElementById("modalOverlay").style.display = "block";
            safeFocus(esEdit ? "f_codigo" : "f_isbn");
        }

        function cerrarModal() { 
            document.getElementById("modalOverlay").style.display = "none"; 
            editando = false; 
            safeFocus("txtBusqueda"); 
        }

        function limpiarCampos() {
            var c = ["f_isbn","f_codigo","f_titulo","f_autor","f_editorial","f_lugar"];
            for(var i=0; i<c.length; i++) document.getElementById(c[i]).value = "";
        }

        function cargarParaEditar(isbn, cod, tit, aut, edi, lug) {
            isbnOriginal = isbn;
            document.getElementById("f_isbn").value = isbn;
            document.getElementById("f_codigo").value = cod;
            document.getElementById("f_titulo").value = tit;
            document.getElementById("f_autor").value = aut;
            document.getElementById("f_editorial").value = edi;
            document.getElementById("f_lugar").value = lug;
            abrirModal(true);
        }
    </script>
</head>

<body onload="inicializar()">
    <div class="wrapper">
        <div class="main-title">Dejalo Ser Libros</div>
        
        <div class="search-area">
            <input type="text" id="txtBusqueda" placeholder="BUSCAR POR ISBN, TÍTULO O AUTOR..." onkeydown="if(event.keyCode==13) consultar()">
            <button class="btn btn-search" onclick="consultar()">Consultar</button>
            <button class="btn btn-clear" onclick="limpiarBusqueda()">Limpiar</button>
            <button class="btn btn-new" onclick="abrirModal(false)">Nuevo Libro</button>
        </div>

        <div class="grid-wrapper">
            <table id="tablaResultados">
                <thead>
                    <tr>
                        <th style="width:15%;">ISBN</th>
                        <th style="width:10%;">CÓDIGO</th>
                        <th style="width:30%;">TÍTULO</th>
                        <th style="width:15%;">AUTOR</th>
                        <th style="width:10%;">EDITORIAL</th>
                        <th style="width:10%;">LUGAR</th>
                        <th style="width:10%;">ACCIONES</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

    <div id="modalOverlay">
        <div id="miniForm">
            <h2 id="modalTitulo" style="font-family:'Courier New'; color:#77a8a8; text-align:center; margin-top:0;">LIBRO</h2>
            
            <div class="form-group">
                <label>ISBN *</label>
                <input type="text" id="f_isbn" onkeydown="return saltar(event, 'f_codigo')" onblur="verificarExistenciaISBN()">
            </div>
            
            <div class="form-group">
                <label>CÓDIGO</label>
                <input type="text" id="f_codigo" onkeydown="return saltar(event, 'f_titulo')">
            </div>
            
            <div class="form-group">
                <label>TÍTULO *</label>
                <input type="text" id="f_titulo" onkeydown="return saltar(event, 'f_autor')">
            </div>
            
            <div class="form-group">
                <label>AUTOR</label>
                <input type="text" id="f_autor" onkeydown="return saltar(event, 'f_editorial')">
            </div>
            
            <div class="form-group">
                <label>EDITORIAL</label>
                <input type="text" id="f_editorial" onkeydown="return saltar(event, 'f_lugar')">
            </div>
            
            <div class="form-group">
                <label>LUGAR</label>
                <input type="text" id="f_lugar" onkeydown="return saltar(event, 'GUARDAR')">
            </div>
            
            <div style="text-align:right; margin-top:15px;">
                <button class="btn btn-edit" onclick="guardar(false)">Guardar</button>
                <button class="btn btn-clear" onclick="cerrarModal()">Cancelar</button>
            </div>
        </div>
    </div>
</body>
</html>